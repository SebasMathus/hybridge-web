# Base de datos PostgreSQL en Neon (obligatorio)
# En Neon: Dashboard → Connection string → copiar la URI.
# Incluir ?sslmode=require si no viene en la URL.
DATABASE_URL=postgresql://usuario:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Secreto para Payload CMS (obligatorio)
PAYLOAD_SECRET=un-secreto-muy-seguro-aqui

# URL del servidor (para URLs de media en producción)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
